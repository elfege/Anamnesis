# MongoDB
MONGO_USER=anamnesis
MONGO_PASSWORD=anamnesis_dev
MONGO_DB=anamnesis

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# App
LOG_LEVEL=INFO

# Ollama (local LLM — free, runs on host)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# Anthropic / Claude API (optional — only used when Claude mode is enabled in chat)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Claude CLI (subscription backend — runs claude binary on remote host via SSH)
CLAUDE_CLI_HOST=localhost
CLAUDE_CLI_PATH=claude

# GPU trainer endpoints (comma-separated)
NANOGPT_URLS=http://localhost:3011

# Machine ID for AnamnesisGPT authorization
AUTHORIZED_MACHINE_ID=

# SSH configuration for remote file access
SSH_USER=your_username
SSH_HOST_SERVER0=host.docker.internal
SSH_HOST_SERVER1=server-1
SSH_HOST_SERVER2=server-2
SSH_HOST_SERVER3=server-3

# Volume mount paths (used in docker-compose.yml)
LOCAL_HOME=/home/your_username
SOURCES_DIR=/path/to/anamnesis_sources
TEACHINGS_DIR=/path/to/teachings
DOCUMENTS_DIR=/path/to/documents
SSH_DIR=~/.ssh

# Trainer volume paths (used in trainers/docker-compose.*.yml)
TRAIN_HOST_DIR=/path/to/training_data
HF_CACHE_DIR=~/.cache/huggingface
