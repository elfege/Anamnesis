0_ANAMNESIS_SOURCES/
*.log



# Docs — only HTML published, not markdown
docs/*.md
0_ANAMNESIS_DOCS_http.server.sh



# Avatar/persona samples — images + audio sources (may be copyright, large)
samples/

# ─── Docker security policy (see Dockerfile.example for rules) ────────────────
# Actual Dockerfiles are gitignored — only `.example` templates are tracked.
# This forces every clone to consciously copy the template, with the security
# header front-and-center, before building. See scripts/security_check.sh too.
Dockerfile
Dockerfile.*
!Dockerfile*.example
!*.dockerignore   # .dockerignore files MUST stay tracked — they're the seatbelt

# Trained model weights (personal-data-encoded — never publish via the runtime image)
d2/d2_checkpoints/
d2/output/
d2_checkpoints/
checkpoints/
*.pt
*.bin
*.safetensors
*.ckpt
*.gguf

# Pre-push security check script (intentionally untracked — easy to edit per machine)
scripts/security_check.sh
app/uploads/
